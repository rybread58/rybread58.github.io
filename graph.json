---
layout: none
permalink: /graph.json
---
{
  "nodes": [
    {% assign all_notes = site.planted-notes | concat: site.growing-notes | concat: site.full-notes %}
    {% assign first = true %}
    {% for note in all_notes %}
      {% unless note.path contains 'place' %}
      {% unless first == false %}{% assign first = false %}{% else %},{% endunless %}
      {
        "id": "{{ note.url }}",
        "title": {{ note.title | jsonify }},
        "url": "{{ note.url }}",
        "stage": "{{ note.stage | default: 'planted' }}"
      }
      {% endunless %}
    {% endfor %}
  ],
  "links": [
    {% for note in all_notes %}
      {% unless note.path contains 'place' %}
        {% if note.links %}
          {% for link in note.links %}
            { "source": "{{ note.url }}", "target": "/{{ link }}/" },
          {% endfor %}
        {% endif %}
      {% endunless %}
    {% endfor %}
    {"source":"__placeholder__","target":"__placeholder__"}
  ]
}
