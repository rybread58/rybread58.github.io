---
layout: none
permalink: /graph.json
---
{% assign all_notes = site.planted-notes | concat: site.growing-notes | concat: site.full-notes %}
{
  "nodes": [
    {% assign first_node = true %}
    {% for note in all_notes %}
      {% unless note.path contains 'place' %}
        {% unless first_node %},{% endunless %}
        {% assign first_node = false %}
        {
          "id": "{{ note.url }}",
          "title": {{ note.title | jsonify }},
          "url": "{{ note.url }}",
          "stage": "{{ note.stage | default: 'planted' }}"
        }
      {% endunless %}
    {% endfor %}
  ],
  "links": [
    {% assign first_link = true %}
    {% for note in all_notes %}
      {% unless note.path contains 'place' %}
        {% if note.links %}
          {% for link in note.links %}
            {% for target_note in all_notes %}
              {% assign target_filename = target_note.path | split: '/' | last | replace: '.md', '' %}
              {% if target_filename == link %}
                {% unless first_link %},{% endunless %}
                {% assign first_link = false %}
                { "source": "{{ note.url }}", "target": "{{ target_note.url }}" }
              {% endif %}
            {% endfor %}
          {% endfor %}
        {% endif %}
      {% endunless %}
    {% endfor %}
  ]
}
